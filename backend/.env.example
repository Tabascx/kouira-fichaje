# ============================================
# KOUIRA FICHAJE - VARIABLES DE ENTORNO
# ============================================

# Puerto del servidor
PORT=3002

# Frontend permitido por CORS
FRONTEND_ORIGIN=http://localhost:3000

# ============================================
# BASE DE DATOS - PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kouira_fichaje
DB_USER=postgres
DB_PASSWORD=admin

# Alternativa: Connection string de Render
# DATABASE_URL=postgresql://user:password@host/dbname

# ============================================
# JWT - Autenticación
# ============================================
# Generar en: https://jwtsecret.com
JWT_SECRET=99090a401e050753ac5b5eccf22af38e07ce98a3bea4e146ddab4eecb339630cf7fbe960bccc9b69593aefac4671da6a
JWT_EXPIRES_IN=8h

# ============================================
# RENDER DEPLOYMENT
# ============================================
# Si despliegas en Render, asegúrate de que estas variables están en Render Dashboard:
# Settings > Environment Variables
#
# Variables obligatorias en Render:
# - DB_HOST: host de PostgreSQL en Render (ej: dpg-xxx.postgres.render.com)
# - DB_PORT: 5432
# - DB_NAME: nombre de la BD
# - DB_USER: usuario de la BD
# - DB_PASSWORD: contraseña de la BD
# - JWT_SECRET: la misma que en local
# - PORT: 3002 (o el que uses)
# - FRONTEND_ORIGIN: https://tu-vercel-domain.vercel.app

